{
  "name": "@aganitha/atk-config",
  "version": "3.1.1",
  "description": "Schema-validated hierarchical configuration with automatic environment support",
  "license": "MIT",
  "author": "Aganitha <support@aganitha.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aganitha/atk-config.git"
  },
  "bugs": {
    "url": "https://github.com/aganitha/atk-config/issues"
  },
  "homepage": "https://github.com/aganitha/atk-config#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "bun test",
    "test:examples": "./examples/run-all.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "configuration",
    "convict",
    "validation",
    "environment"
  ],
  "engines": {
    "node": ">=16.9.0"
  },
  "dependencies": {
    "convict": "^6.2.4",
    "convict-format-with-validator": "^6.2.0",
    "yaml": "^2.8.2",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/convict": "^6.1.6",
    "commander": "^12.0.0",
    "typescript": "^5"
  }
}
